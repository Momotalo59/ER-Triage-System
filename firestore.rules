rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // อนุญาตให้อ่านและเขียนข้อมูลได้ทั้งหมดในช่วงการพัฒนาต้นแบบ (Prototype)
      // เพื่อให้ระบบบันทึกและ Redirect ทำงานได้โดยไม่ติดเรื่องสิทธิ์
      allow read, write: if true;
    }
  }
}