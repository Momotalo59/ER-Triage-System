rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // เปิดสิทธิ์ให้อ่านและเขียนข้อมูลได้ทั้งหมดสำหรับการใช้งานจริงในเฟสแรก
      // เพื่อให้แอปพลิเคชันสามารถบันทึกข้อมูลผู้ป่วยและทรัพยากรได้ทันที
      allow read, write: if true;
    }
  }
}