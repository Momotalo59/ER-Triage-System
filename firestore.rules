rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * สำหรับช่วง Prototype: อนุญาตให้เข้าถึงข้อมูลได้ทั้งหมดโดยไม่ต้องตรวจสอบสิทธิ์
     * เพื่อป้องกันปัญหา Permission Denied ในระหว่างการพัฒนา
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}