rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CRISIS TRIAGE DASHBOARD SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset implements a Role-Based Access Control (RBAC) model.
     * In the prototype stage, all authenticated users are granted access to clinical data
     * to ensure smooth development and testing.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the requester is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description For the prototype, all signed-in users have medical clearance. */
    function isMedicalPersonnel() {
      return isSignedIn();
    }

    /** @description Verifies the document exists and the requester has medical clearance. */
    function canModifyOperationalData() {
      return isMedicalPersonnel() && (resource != null || request.method == 'create');
    }

    /** @description Ensures a field remains unchanged during an update. */
    function isUnchanged(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    // --- COLLECTION RULES ---

    /**
     * @description Authorization lookup for medical personnel.
     */
    match /roles_medical_personnel/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if isMedicalPersonnel();
    }

    /**
     * @description Clinical records for patients in the Emergency Department.
     */
    match /patients/{patientId} {
      allow get, list: if isMedicalPersonnel();
      allow create: if isMedicalPersonnel();
      allow update: if isMedicalPersonnel();
      allow delete: if isMedicalPersonnel();
    }

    /**
     * @description Stock levels and inventory management for blood types.
     */
    match /blood_inventory/{bloodTypeId} {
      allow get, list: if isMedicalPersonnel();
      allow create, update, delete: if isMedicalPersonnel();
    }

    /**
     * @description Tracking and assignment of ventilator equipment.
     */
    match /ventilators/{ventilatorId} {
      allow get, list: if isMedicalPersonnel();
      allow create, update, delete: if isMedicalPersonnel();
    }
    
    /**
     * @description MCI Plans management.
     */
    match /mci_plans/{planId} {
      allow get, list: if isMedicalPersonnel();
      allow create, update, delete: if isMedicalPersonnel();
    }

    /**
     * @description Resource tracking.
     */
    match /resources/{resourceId} {
      allow get: if isMedicalPersonnel();
      allow write: if isMedicalPersonnel();
    }
  }
}