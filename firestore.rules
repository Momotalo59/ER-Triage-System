rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // อนุญาตให้ทุกคน (ทั้งที่ล็อกอินและไม่ล็อกอิน) สามารถอ่านและเขียนข้อมูลได้ทั้งหมด
    // เพื่อความสะดวกในการทำ Prototype และทดสอบระบบ MCI
    match /{document=**} {
      allow read, write: if true;
    }
  }
}