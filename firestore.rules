rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * สำหรับช่วง Prototype: อนุญาตให้ผู้ที่ล็อกอินแล้ว (รวมถึง Anonymous) 
     * สามารถอ่านและเขียนข้อมูลในทุกคอลเลกชันได้
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}