rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // เปิดสิทธิ์ให้อ่านและเขียนข้อมูลได้ทั้งหมดในช่วงการพัฒนา
      // เพื่อให้ระบบทำงานได้ลื่นไหลและบันทึกข้อมูลผู้ป่วย/ทรัพยากรได้จริง
      allow read, write: if true;
    }
  }
}